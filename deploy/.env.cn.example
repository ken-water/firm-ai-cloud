# CloudOps One local dependency stack (China mirror profile)
# Copy to deploy/.env for China-network environments.

# Image sources (docker.1ms.run mirror)
POSTGRES_IMAGE=docker.1ms.run/library/postgres:16-alpine
REDIS_IMAGE=docker.1ms.run/library/redis:7-alpine
OPENSEARCH_IMAGE=docker.1ms.run/opensearchproject/opensearch:2.15.0
MINIO_IMAGE=docker.1ms.run/minio/minio:RELEASE.2025-01-20T14-49-07Z
ZABBIX_DB_IMAGE=docker.1ms.run/library/mysql:8.0
ZABBIX_SERVER_IMAGE=docker.1ms.run/zabbix/zabbix-server-mysql:alpine-7.0-latest
ZABBIX_WEB_IMAGE=docker.1ms.run/zabbix/zabbix-web-nginx-mysql:alpine-7.0-latest
ZABBIX_PROXY_IMAGE=docker.1ms.run/zabbix/zabbix-proxy-sqlite3:alpine-7.0-latest
ZABBIX_AGENT_IMAGE=docker.1ms.run/zabbix/zabbix-agent:alpine-7.0-latest

POSTGRES_DB=cloudops
POSTGRES_USER=cloudops
POSTGRES_PASSWORD=cloudops_local_change_me
POSTGRES_PORT=5432

REDIS_PORT=6379

OPENSEARCH_PORT=9200
OPENSEARCH_PERF_PORT=9600
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
OPENSEARCH_INITIAL_ADMIN_PASSWORD=CloudOps_Admin_2026!

MINIO_ROOT_USER=cloudopsadmin
MINIO_ROOT_PASSWORD=cloudops_minio_change_me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

ZABBIX_DB_NAME=zabbix
ZABBIX_DB_USER=zabbix
ZABBIX_DB_PASSWORD=zabbix_change_me
ZABBIX_DB_ROOT_PASSWORD=zabbix_root_change_me
ZABBIX_SERVER_BIND_HOST=0.0.0.0
ZABBIX_SERVER_PORT=10051
ZABBIX_PROXY_BIND_HOST=0.0.0.0
ZABBIX_PROXY_PORT=10061
ZABBIX_WEB_PORT=8082
ZABBIX_PROXY_HOSTNAME=cloudops-proxy
ZABBIX_LOCAL_AGENT_HOSTNAME=cloudops-local-agent
ZABBIX_PHP_TZ=Asia/Shanghai
ZABBIX_STARTPOLLERS=15
ZABBIX_CACHE_SIZE=128M

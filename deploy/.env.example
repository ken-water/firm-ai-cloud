# CloudOps One local dependency stack
# Copy to deploy/.env and adjust values for your environment.

# Image sources (default: Docker Hub)
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
OPENSEARCH_IMAGE=opensearchproject/opensearch:2.15.0
MINIO_IMAGE=minio/minio:RELEASE.2025-01-20T14-49-07Z

POSTGRES_DB=cloudops
POSTGRES_USER=cloudops
POSTGRES_PASSWORD=cloudops_local_change_me
POSTGRES_PORT=5432

REDIS_PORT=6379

OPENSEARCH_PORT=9200
OPENSEARCH_PERF_PORT=9600
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
OPENSEARCH_INITIAL_ADMIN_PASSWORD=CloudOps_Admin_2026!

MINIO_ROOT_USER=cloudopsadmin
MINIO_ROOT_PASSWORD=cloudops_minio_change_me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
